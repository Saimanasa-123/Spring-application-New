pipeline {
    agent any

    stages{
        stage('build and test'){
            steps{
                sh 'echo "Building and testing the application..."'
                sh 'ls -ltr'
                sh 'mvn clean package'

            }
        }
        stage('sonarqube testing and code quality check'){
            environment {
                SONAR_URL = "http://172.30.242.84:9000/"
            }   
            steps {
        withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
        sh 'mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
        }
    }
        
    }

    stage('build and push to docker hub'){
        environment {
            DOCKERHUB_IMAGE = "saimanasabethu/ultimate-cicd:${BUILD_NUMBER}"
            REGISTRY_CREDENTIALS = credentials('docker-cred')

        }
        steps {
        script {
            sh 'docker build -t ${DOCKER_IMAGE} .'
            def dockerImage = docker.image("${DOCKER_IMAGE}")
            docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
                dockerImage.push()
            }
        }
    }
    }
    stage('Update Deployment File') {
        environment {
            GIT_REPO_NAME = "Spring-application-New"
            GIT_USER_NAME = "Saimanasa-123"
        }
        steps {
            withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                sh '''
                    git config user.email "saimanasabethu@gmail.com"
                    git config user.name "Saimanasa-123"
                    BUILD_NUMBER=${BUILD_NUMBER}
                    sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" k8s/deployment.yml
                    git add k8s/deployment.yml
                    git commit -m "Update deployment image to version ${BUILD_NUMBER}"
                    git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                '''
            }
        }
    }

}
}
